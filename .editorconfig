# Editor defaults for itera. Mirrors what treefmt (nixfmt-rfc-style + prettier)
# already enforces in CI, so editors without the devShell match on save.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Preserve hard line breaks (two trailing spaces) in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
